# Platform: telegram | max | both
PLATFORM=telegram

# Telegram (from @BotFather)
TELEGRAM_BOT_TOKEN=
# Имя бота для return_url после оплаты ЮKassa (например MyMotoBot)
TELEGRAM_BOT_USERNAME=
# Прокси к api.telegram.org, если хост не имеет прямого доступа.
# Поддерживается http://, https://, socks5:// (последнее требует aiohttp-socks).
# Пример: TELEGRAM_PROXY=http://172.18.0.1:40001
TELEGRAM_PROXY=

# MAX (from business.max.ru)
MAX_BOT_TOKEN=
# Имя бота MAX для return_url (например id123456_bot)
MAX_BOT_USERNAME=
MAX_API_BASE=https://platform-api.max.ru
# Публичный HTTPS-URL, на который MAX будет POSTить апдейты.
# Если задан — бот регистрирует подписку через POST /subscriptions
# вместо long polling. Последний сегмент пути работает как секрет авторизации.
# Пример: MAX_WEBHOOK_URL=https://your-domain/webhook/max/<random_hex>
MAX_WEBHOOK_URL=

# PostgreSQL (async)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/moto_bot

# Redis (FSM, cache)
REDIS_URL=redis://localhost:6379/0

# YooKassa: в тесте — shop_id и ключ с префиксом test_; в бою — shop_id и secret из боевого магазина (ключ с live_)
# shop_id боевого магазина обычно отличается от тестового
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Webhook server port for YooKassa (default 8080)
WEBHOOK_PORT=8080
# За nginx с proxy_set_header X-Real-IP — включи true, иначе проверка IP ЮKassa не сработает
WEBHOOK_TRUST_PROXY=false

# Суперадмины: через запятую — Telegram user_id и/или MAX user_id (числа из логов: platform_user_id).
# Если админишь и из Telegram, и из MAX — укажи оба ID, иначе часть уведомлений уйдёт «в никуда».
# MAX user_id — число из логов сервера (platform_user_id при входящем сообщении) или поддержка.
SUPERADMIN_IDS=123456789,987654321

# Support
SUPPORT_USERNAME=support
SUPPORT_EMAIL=support@example.com

# SOS cooldown (seconds)
SOS_COOLDOWN_SECONDS=600

# Limits
ABOUT_TEXT_MAX_LENGTH=500

# Default prices (kopecks)
SUBSCRIPTION_MONTHLY_PRICE=29900
SUBSCRIPTION_SEASON_PRICE=79900
EVENT_CREATION_PRICE=9900
RAISE_PROFILE_PRICE=4900
